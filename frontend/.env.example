# Vite environment variables (must start with VITE_ to be accessible in the browser)

# Backend API base URL
# For local development, defaults to http://localhost:8000/api
# For production, set this to your deployed backend URL, e.g.:
# VITE_API_BASE_URL=https://api.yourdomain.com/api
VITE_API_BASE_URL=

# Note: Copy this file to .env.local for local development
# Vercel will automatically inject these from Environment Variables settings