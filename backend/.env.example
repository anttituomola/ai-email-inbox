# Copy this file to .env and add your API key
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-nano

# CORS Origins - comma-separated list of allowed frontend origins
# For local development, defaults to http://localhost:5173
# For production, add your Vercel domain(s) here, e.g.:
# CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=

# Database URL (optional)
# For local development, defaults to sqlite+aiosqlite:///./inbox.db (local file)
# For Docker deployment, set to sqlite+aiosqlite:///data/inbox.db for persistent volume
DATABASE_URL=
